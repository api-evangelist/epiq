      "@id": "epiq:filingDate",
      "@type": "xsd:date"
    },
    "court": {
      "@id": "epiq:court",
      "@type": "xsd:string"
    },
    "district": {
      "@id": "epiq:district",
      "@type": "xsd:string"
    },
    "debtor": {
      "@id": "epiq:debtor",
      "@type": "xsd:string"
    },
    "trustee": {
      "@id": "epiq:trustee",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "epiq:status",
      "@type": "xsd:string"
    },
