{
  "@context": {
    "@version": 1.1,
    "epiq": "https://api-evangelist.github.io/epiq/vocab#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "legal": "https://schema.org/LegalService",

    "caseId": {
      "@id": "epiq:caseId",
