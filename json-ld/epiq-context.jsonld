      "@id": "epiq:currency",
      "@type": "xsd:string"
    },
    "paymentMethod": {
      "@id": "epiq:paymentMethod",
      "@type": "xsd:string"
    },
    "paymentStatus": {
      "@id": "epiq:paymentStatus",
      "@type": "xsd:string"
    },
    "disbursementDate": {
      "@id": "epiq:disbursementDate",
      "@type": "xsd:date"
    },
    "paymentAmount": {
      "@id": "epiq:paymentAmount",
      "@type": "xsd:decimal"
    },
    "transactionId": {
      "@id": "epiq:transactionId",
      "@type": "xsd:string"
    },

    "matterId": {
      "@id": "epiq:matterId",
      "@type": "xsd:string"
    },
    "matterName": {
      "@id": "epiq:matterName",
      "@type": "xsd:string"
    },
